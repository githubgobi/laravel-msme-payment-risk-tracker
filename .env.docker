# ============================================================
# Docker Compose environment — local development only
# Copy this file as-is; do NOT commit real secrets.
# After first `docker compose up`, run:
#   docker compose exec app php artisan key:generate
#   docker compose exec app php artisan migrate --seed
#   docker compose exec ollama ollama pull qwen2.5:3b
# ============================================================

APP_NAME="MSME 43B(h) Tracker"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN

LOG_CHANNEL=stderr
LOG_LEVEL=debug

# ── Database — service name 'db' resolves inside Docker network ──────────────
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=msme_tracker
DB_USERNAME=msme_user
DB_PASSWORD=secret

# ── Redis — service name 'redis' ─────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=2

SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false

CACHE_STORE=redis
CACHE_PREFIX=msme_

QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Mail (log driver — inspect with `docker compose logs app`) ───────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@msme-tracker.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Razorpay — use test keys locally ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=placeholder
RAZORPAY_WEBHOOK_SECRET=placeholder
RAZORPAY_PLAN_STARTER=plan_placeholder
RAZORPAY_PLAN_PROFESSIONAL=plan_placeholder
RAZORPAY_PLAN_ENTERPRISE=plan_placeholder

# ── Surepass (Udyam verification) — leave blank to skip in local dev ─────────
SUREPASS_API_KEY=

# ── WhatsApp ─────────────────────────────────────────────────────────────────
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME=msme_43bh_alert
AISENSY_USER_NAME="MSME Tracker"

# ── Ollama — service name 'ollama' ───────────────────────────────────────────
LLM_ENABLED=true
LLM_ENDPOINT=http://ollama:11434
LLM_MODEL=qwen2.5:3b
LLM_TIMEOUT=60
LLM_CONFIDENCE_THRESHOLD=0.80
LLM_MAX_MATCH_CANDIDATES=20

VITE_APP_NAME="${APP_NAME}"
VITE_RAZORPAY_KEY_ID="${RAZORPAY_KEY_ID}"
