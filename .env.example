# ============================================================
# MSME 43B(h) Payment Risk Tracker — Environment Template
# Copy to .env and fill in all REQUIRED values before deploying
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_NAME="MSME 43B(h) Tracker"
APP_ENV=production          # Change to 'local' for development
APP_KEY=                    # REQUIRED: php artisan key:generate
APP_DEBUG=false             # NEVER true in production
APP_URL=https://msme-tracker.in

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_IN      # Indian locale for test data (names, phone numbers)

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ──────────────────────────────────────────────────
LOG_CHANNEL=daily           # Rotates daily; 14-day retention
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning           # Use 'debug' locally only

# ── Database (MySQL 8) ────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=msme_tracker    # REQUIRED
DB_USERNAME=msme_user       # REQUIRED
DB_PASSWORD=                # REQUIRED

# ── Session (Redis DB 1) ──────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=480        # 8 hours
SESSION_ENCRYPT=true        # Encrypt session data at rest
SESSION_PATH=/
SESSION_DOMAIN=.msme-tracker.in

# ── Cache (Redis DB 2) ────────────────────────────────────────
CACHE_STORE=redis
CACHE_PREFIX=msme_

# ── Queues (Redis DB 0) ───────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ── Redis ─────────────────────────────────────────────────────
REDIS_CLIENT=predis         # Use predis (phpredis extension not required)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=             # REQUIRED in production (see deploy/redis.conf)
REDIS_PORT=6379
REDIS_DB=2                  # Cache database index
REDIS_CACHE_DB=2

# ── Mail ──────────────────────────────────────────────────────
# Recommended: Resend (transactional email for India, great deliverability)
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=              # REQUIRED: Resend API key
MAIL_FROM_ADDRESS="noreply@msme-tracker.in"
MAIL_FROM_NAME="${APP_NAME}"
# OR use MAIL_MAILER=resend with RESEND_API_KEY=re_...

# ── Razorpay (Subscription Billing) ──────────────────────────
# Dashboard: https://dashboard.razorpay.com
RAZORPAY_KEY_ID=            # REQUIRED: rzp_live_...
RAZORPAY_KEY_SECRET=        # REQUIRED: keep secret, never commit
RAZORPAY_WEBHOOK_SECRET=    # REQUIRED: set in Razorpay dashboard > Webhooks
RAZORPAY_PLAN_STARTER=      # REQUIRED: plan_... ID from Razorpay dashboard
RAZORPAY_PLAN_PROFESSIONAL= # REQUIRED
RAZORPAY_PLAN_ENTERPRISE=   # REQUIRED

# ── Surepass (Udyam / MSME Verification API) ─────────────────
# Sign up at: https://surepass.io
SUREPASS_API_KEY=           # REQUIRED for Udyam verification feature

# ── AiSensy (WhatsApp Business API — India) ───────────────────
# Sign up at: https://aisensy.com
# Pre-approve template name: msme_43bh_alert
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME=msme_43bh_alert
AISENSY_USER_NAME="MSME Tracker"

# ── AWS S3 (optional — for backup storage) ────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Vite ─────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_RAZORPAY_KEY_ID="${RAZORPAY_KEY_ID}"

# ── Local AI / LLM (Ollama) ──────────────────────────────────
# Install Ollama: https://ollama.ai  →  ollama pull qwen2.5:3b
LLM_ENABLED=false                   # Set true after Ollama is running
LLM_ENDPOINT=http://localhost:11434
LLM_MODEL=qwen2.5:3b
LLM_TIMEOUT=30
LLM_CONFIDENCE_THRESHOLD=0.80       # 0.80 = 80% — auto-apply above this
LLM_MAX_MATCH_CANDIDATES=20

# ── Development overrides (local only — do not set in production) ──
# SESSION_DRIVER=file
# CACHE_STORE=file
# QUEUE_CONNECTION=sync
# APP_DEBUG=true
# LOG_LEVEL=debug
